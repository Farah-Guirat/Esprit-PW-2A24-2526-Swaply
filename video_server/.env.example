# ─── Video Server Configuration ─────────────────────────────────────────────

# Port d'écoute du serveur de signalisation
PORT=3000

# Origines autorisées pour CORS (séparer par virgule)
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3306,http://localhost

# Configuration WebRTC
STUN_SERVERS=["stun:stun.l.google.com:19302","stun:stun1.l.google.com:19302"]
TURN_SERVER=
TURN_USERNAME=
TURN_PASSWORD=

# Logging
LOG_LEVEL=debug
